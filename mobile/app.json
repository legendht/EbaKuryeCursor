{
  "expo": {
    "name": "EBA Kurye",
    "slug": "eba-kurye",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ebakurye.courier",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "EBA Kurye, siparişleri yönetmek için arka planda konumunuza ihtiyaç duyar.",
        "NSLocationAlwaysUsageDescription": "EBA Kurye, teslimat sırasında arka planda konumunuzu takip eder.",
        "NSCameraUsageDescription": "Teslimat kanıtı fotoğrafı çekmek için kamera gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.ebakurye.courier",
      "versionCode": 3,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "EBA Kurye arka planda konumunuzu takip eder.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Teslimat fotoğrafı için kamera izni gereklidir."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "781edb17-34e5-4c4b-b26d-ddee487f6d22"
      }
    },
    "owner": "hakantektas"
  }
}
